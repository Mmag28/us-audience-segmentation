# ============================================================
# Outputs
# ============================================================

# Ignore generated outputs by default
outputs/**
!outputs/
!outputs/figures/
!outputs/tables/

# Keep folder placeholders
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep

# Keep one small example output visible
!outputs/tables/11_us_audience_segments_v1.csv

